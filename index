        <div class="card-name">Em Breve</div>
        <div class="card-role">CS Specialist</div>
      </div>
      <span class="badge badge-soon">Em breve</span>
    </div>

    <!-- Em Breve 5 -->
    <div class="card soon">
      <div class="avatar-placeholder">👤</div>
      <div>
        <div class="card-name">Em Breve</div>
        <div class="card-role">CS Specialist</div>
      </div>
      <span class="badge badge-soon">Em breve</span>
    </div>

  </div>
</main>

<footer>CS Reports · inChurch · 2026</footer>

</body>
</html>
